# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cubo_ai

# JWT
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for API keys at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS
CORS_ORIGIN=http://localhost:5173
